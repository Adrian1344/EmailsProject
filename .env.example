# Exemplo de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus dados

# Não é necessário para a aplicação funcionar localmente
# pois o arquivo alunos2.json será lido do disco

# Se preferir usar uma variável de ambiente no Vercel:
# ALUNOS_DATA={"nome":"...","email":"..."}

# Ou use o arquivo alunos2.json diretamente (recomendado)
# Certifique-se de fazer upload do arquivo para o Vercel
